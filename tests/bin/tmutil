#!/usr/bin/env bash
#
# A mock implementation of Apple's Time Machine utility (tmutil).
#
# Uses the ASIMOV_TEST_EXCLUSIONS environment variable, which should point
# to a temporary file that acts as the exclusion database.

set -euo pipefail

if [[ -z "${ASIMOV_TEST_EXCLUSIONS:-}" ]]; then
  echo "Error: ASIMOV_TEST_EXCLUSIONS is not set." >&2
  exit 1
fi

subcommand="${1:-}"
shift || true

case "$subcommand" in
  isexcluded)
    path="${1:-}"
    # A path is excluded if it — or any ancestor directory — is in the exclusion
    # database. Real tmutil reports descendants of a path-based exclusion as
    # excluded too (TM exclusions are recursive), so a manually excluded parent
    # like ~/.nvm covers ~/.nvm/.../node_modules.
    excluded=false
    probe="$path"
    while :; do
      if grep -Fxq "$probe" "$ASIMOV_TEST_EXCLUSIONS" 2>/dev/null; then
        excluded=true
        break
      fi
      parent="$(dirname "$probe")"
      [[ "$parent" == "$probe" ]] && break
      probe="$parent"
    done
    if [[ "$excluded" == true ]]; then
      printf '[Excluded]\t%s\n' "$path"
    else
      printf '[Included]\t%s\n' "$path"
    fi
    ;;
  addexclusion)
    # Supports multiple paths: tmutil addexclusion path1 path2 ...
    for path in "$@"; do
      # Simulate failure for paths listed in ASIMOV_TEST_TMUTIL_FAIL_PATHS
      if [[ -n "${ASIMOV_TEST_TMUTIL_FAIL_PATHS:-}" && -f "${ASIMOV_TEST_TMUTIL_FAIL_PATHS}" ]]; then
        if grep -Fxq "$path" "$ASIMOV_TEST_TMUTIL_FAIL_PATHS" 2>/dev/null; then
          echo "Error (-50) while attempting to change exclusion setting." >&2
          exit 1
        fi
      fi
      # Idempotent: don't add if already present (matches real tmutil)
      if ! grep -Fxq "$path" "$ASIMOV_TEST_EXCLUSIONS" 2>/dev/null; then
        printf '%s\n' "$path" >> "$ASIMOV_TEST_EXCLUSIONS"
      fi
    done
    ;;
  *)
    echo "Unknown subcommand: $subcommand" >&2
    exit 1
    ;;
esac
